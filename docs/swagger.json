    "definitions": {
        "dnsapi.CreateRecordRequest": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "example": "www"
                },
                "prio": {
                    "type": "integer",
                    "example": 0
                },
                "ttl": {
                    "type": "integer",
                    "example": 3600
                },
                "type": {
                    "type": "string",
                    "example": "A"
                },
                "value": {
                    "type": "string",
                    "example": "1.2.3.4"
                }
            }
        },
        "dnsapi.CreateZoneRequest": {
            "type": "object",
            "properties": {
                "abuse_email": {
                    "type": "string",
                    "example": "admin@example.com"
                },
                "domain": {
                    "type": "string",
                    "example": "example.com"
                },
                "owner": {
                    "type": "string",
                    "example": "alice"
                },
                "tags": {
                    "type": "string",
                    "example": "tag1,tag2"
                }
            }
        },
        "dnsapi.DNSCheckRecord": {
            "type": "object",
            "properties": {
                "db_value": {
                    "type": "string"
                },
                "error": {
                    "type": "string"
                },
                "fqdn": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "primary_ok": {
                    "type": "boolean"
                },
                "primary_values": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "record_id": {
                    "type": "integer"
                },
                "secondary_ok": {
                    "type": "boolean"
                },
                "secondary_values": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "supported": {
                    "type": "boolean"
                },
                "type": {
                    "type": "string"
                }
            }
        },
        "dnsapi.DNSCheckResponse": {
            "type": "object",
            "properties": {
                "domain": {
                    "type": "string"
                },
                "primary_ns": {
                    "type": "string"
                },
                "records": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/dnsapi.DNSCheckRecord"
                    }
                },
                "secondary_ns": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "zone_id": {
                    "type": "integer"
                }
            }
        },
        "dnsapi.ErrorResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                }
            }
        },
        "dnsapi.MessageResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string"
                }
            }
        },
        "dnsapi.Record": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "name": {
                    "type": "string"
                },
                "prio": {
                    "type": "integer"
                },
                "ttl": {
                    "type": "integer"
                },
                "type": {
                    "description": "A, AAAA, CNAME, TXT, SRV",
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                },
                "value": {
                    "type": "string"
